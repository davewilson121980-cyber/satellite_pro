FLASK_APP=app.py
FLASK_ENV=development
SECRET_KEY=your-secret-key-change-in-production
DATABASE_URL=sqlite:///satellite_data.db

# NASA POWER API (no key required, free for research)
NASA_POWER_API_URL=https://power.larc.nasa.gov/api/temporal/daily/point

# Sentinel-Hub API (get credentials from https://apps.sentinel-hub.com/)
SENTINEL_HUB_API_URL=https://services.sentinel-hub.com
SENTINEL_HUB_CLIENT_ID=your-client-id
SENTINEL_HUB_CLIENT_SECRET=your-client-secret

# Stripe (simulated payments)
STRIPE_SECRET_KEY=sk_test_your-stripe-secret-key
STRIPE_PUBLISHABLE_KEY=pk_test_your-stripe-publishable-key

# PostGIS (set to True if using PostgreSQL with PostGIS)
POSTGIS_ENABLED=False
